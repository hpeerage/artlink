# Turso (LibSQL)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Optional: Portone (Payment)
NEXT_PUBLIC_PORTONE_STORE_ID=your_store_id
PORTONE_API_KEY=your_api_key
PORTONE_API_SECRET=your_api_secret

# Google Sheets Integration
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Key_Content\n-----END PRIVATE KEY-----\n"
